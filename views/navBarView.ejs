<!-- partials/navBarView.ejs -->

<nav class="bg-[#AF0A08] text-white shadow-md">

  <div class="max-w-6xl mx-auto px-6 py-4 flex flex-col gap-4 md:flex-row md:items-center md:justify-between">

    <!-- LEFT SIDE -->
    <div class="flex items-center gap-6">

      <!-- Logo -->
      <a 
        href="/"
        class="text-3xl font-bold tracking-wide hover:opacity-90 transition"
      >
        Aid Stock
      </a>

      <!-- Navigation Links -->
      <div class="flex gap-3">

        <a 
          href="/categories"
          class="px-4 py-2 rounded-lg bg-[#ec8f8e] hover:bg-[#E09524] transition duration-200 shadow-sm"
        >
          Categories
        </a>

        <a 
          href="/items"
          class="px-4 py-2 rounded-lg bg-[#ec8f8e] hover:bg-[#E09524] transition duration-200 shadow-sm"
        >
          Items
        </a>

      </div>

    </div>

    <!-- RIGHT SIDE -->
    <form 
      method="GET"
      action="/items/search"
      class="flex gap-2"
    >

      <input
        type="text"
        name="users_name"
        placeholder="Search items..."
        class="px-4 py-2 rounded-lg text-stone-800 bg-white outline-none border border-transparent focus:border-[#E09524] focus:ring-2 focus:ring-[#E09524] w-56"
      />

      <button
        type="submit"
        class="px-4 py-2 rounded-lg bg-[#E09524] hover:bg-[#D67E00] transition duration-200 shadow-sm"
      >
        Search
      </button>

    </form>

  </div>

</nav>

