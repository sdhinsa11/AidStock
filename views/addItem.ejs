<html>

<head>

  <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>

  <link
    href="https://fonts.googleapis.com/css2?family=Quicksand:wght@400;500;700&display=swap"
    rel="stylesheet"
  >

  <title>Add Item | Aid Stock</title>

</head>

<body class="font-['Quicksand'] bg-[#EDDABF]/30 min-h-screen text-stone-800">

  <%- include('navBarView') %>

  <main class="max-w-3xl mx-auto px-6 py-12">

    <!-- Form Card -->
    <div class="bg-white rounded-3xl shadow-xl border border-[#E0C27D] p-10">

      <!-- Header -->
      <div class="mb-10">

        <p class="uppercase tracking-widest text-sm text-[#AF0A08] font-semibold">
          Inventory Management
        </p>

        <h1 class="text-5xl font-bold text-[#AF0A08] mt-2">
          Add New Item
        </h1>

        <p class="text-stone-600 mt-3">
          Create a new inventory item and assign it to a category.
        </p>

      </div>

      <!-- Form -->
      <form method="POST" action="/items/newItem" class="space-y-6">

        <!-- Item Name -->
        <div>

          <label class="block text-sm font-semibold mb-2">
            Item Name
          </label>

          <input
            type="text"
            name="item_name"
            class="w-full px-4 py-3 rounded-2xl border border-[#E0C27D] focus:outline-none focus:ring-2 focus:ring-[#E09524]"
            placeholder="Enter item name"
          />

        </div>

        <!-- Description -->
        <div>

          <label class="block text-sm font-semibold mb-2">
            Description
          </label>

          <textarea
            name="desc"
            rows="4"
            class="w-full px-4 py-3 rounded-2xl border border-[#E0C27D] focus:outline-none focus:ring-2 focus:ring-[#E09524]"
            placeholder="Describe the item"
          ></textarea>

        </div>

        <!-- Quantity -->
        <div>

          <label class="block text-sm font-semibold mb-2">
            Quantity
          </label>

          <input
            type="number"
            name="quantity"
            class="w-full px-4 py-3 rounded-2xl border border-[#E0C27D] focus:outline-none focus:ring-2 focus:ring-[#E09524]"
            placeholder="0"
          />

        </div>

        <!-- Unit -->
        <div>

          <label class="block text-sm font-semibold mb-2">
            Unit
          </label>

          <input
            type="text"
            name="unit"
            class="w-full px-4 py-3 rounded-2xl border border-[#E0C27D] focus:outline-none focus:ring-2 focus:ring-[#E09524]"
            placeholder="kg, boxes, bags..."
          />

        </div>

        <!-- Expiration -->
        <div>

          <label class="block text-sm font-semibold mb-2">
            Expiration Date
          </label>

          <input
            type="date"
            name="exp_date"
            class="w-full px-4 py-3 rounded-2xl border border-[#E0C27D] focus:outline-none focus:ring-2 focus:ring-[#E09524]"
          />

        </div>

        <!-- Category -->
        <div>

          <label class="block text-sm font-semibold mb-2">
            Category
          </label>

          <select
            name="category_id"
            class="w-full px-4 py-3 rounded-2xl border border-[#E0C27D] focus:outline-none focus:ring-2 focus:ring-[#E09524]"
          >

            <% categories.forEach((category) => { %>

              <option value="<%= category.id %>">
                <%= category.name %>
              </option>

            <% }) %>

          </select>

        </div>

        <!-- Buttons -->
        <div class="flex gap-4 pt-4">

          <button
            type="submit"
            class="px-6 py-3 rounded-2xl bg-[#AF0A08] text-white hover:bg-[#8f0806] transition duration-200 shadow-md"
          >
            Add Item
          </button>

          <a
            href="<%= backLink %>"
            class="px-6 py-3 rounded-2xl bg-[#EDDABF] hover:bg-[#E0C27D] transition duration-200"
          >
            Cancel
          </a>

        </div>

      </form>

    </div>

  </main>

</body>

</html>

			
