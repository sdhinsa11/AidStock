
<html>
	<head> 
		<!-- Refer to the indexStyles.css as this and not as ../public/indexStyles.css -->
		<link rel="stylesheet" href="/indexStyles.css">
		<link href="https://fonts.googleapis.com/css2?family=Quicksand&display=swap" rel="stylesheet">
	</head>
	<body>
		<%-include('navBarView')%>
		<div class="main - items">

			<div class="items - all">
				<%items.forEach((item)=>{%>
				<ul>
					<li>
						<!-- We have a link here to the item so when we click it it redirects to that link using the item id (route we set up in indexRouter) -->
						<!-- <a href="/items/<%= item.id %>">
							<%=item.name%>
						</a> -->

						<!-- This sets the returnTo parameter to the original url so when we touch the item it holds the returnTo parameter for the back link  -->
						<a href="/items/<%= item.id %>?returnTo=<%= encodeURIComponent(originalUrl) %>">
                    		<%= item.name %>
                		</a>
						
					</li>

					<li>
						<%=item.description%>
					</li>
					
					<li>
						<%=item.quantity%>
					</li>
					
				</ul>
				<%});%>
			</div>

			<!-- This will either go back to the home page (if press items) or the category page -->
			<div class="links"><a href="<%= backLink %>">Back</a></div> 
		
			<!-- <div class="links - addBtn">
				<a href="/new">New Item</a>
			</div> -->
		</div>
	</body>
	
</html>

 